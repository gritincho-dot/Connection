modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "static"
build = ["bash", "-c", "pnpm install && cd artifacts/circle-link && node scripts/build.js"]
publicDir = "artifacts/circle-link/dist"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Circle Link"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Dev"

[[workflows.workflow]]
name = "Circle Link"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/circle-link && node scripts/build.js && PORT=5000 node server/serve.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Expo Dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/circle-link && PORT=8080 pnpm run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 20213
externalPort = 3000

[[ports]]
localPort = 20214
externalPort = 3001
